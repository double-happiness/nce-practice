{
  "not only ... but also": {
    "collocations": [
      { "en": "not only ... but also ...", "cn": "不仅……而且……" },
      { "en": "not only A but B as well", "cn": "A 如此，B 也如此" }
    ],
    "patterns": [{
      "title": "not only ... but also",
      "explain": "连接两个并列成分；not only 放句首时，主句需部分倒装（助动词提前）。",
      "examples": [
        "She not only sings but also dances.",
        "Not only did he finish early, but he also helped others."
      ]
    }]
  },
  "every time": {
    "collocations": [
      { "en": "every time + 从句", "cn": "每当……就……" },
      { "en": "Every time I see her, ...", "cn": "每次见到她……" }
    ],
    "patterns": [{
      "title": "every time / whenever",
      "explain": "引导时间状语从句，表示每次发生某事时都会……",
      "examples": [
        "Every time I pass this shop, I think of my grandmother.",
        "Whenever it rains, he stays at home."
      ]
    }]
  },
  "whenever": {
    "collocations": [
      { "en": "whenever + 从句", "cn": "每当；无论何时" }
    ]
  },
  "may have done": {
    "collocations": [
      { "en": "may/might have done", "cn": "可能做过（对过去的推测）" },
      { "en": "can't have done", "cn": "不可能做过" }
    ],
    "patterns": [{
      "title": "may/might have done",
      "explain": "情态动词 + have + 过去分词，表示对过去情况的推测。",
      "examples": [
        "He may have missed the train.",
        "She can't have finished so quickly."
      ]
    }]
  },
