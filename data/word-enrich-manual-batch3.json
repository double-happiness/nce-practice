    ],
    "patterns": [{
      "title": "be worth + 名词/动名词",
      "explain": "worth 后接名词或动名词，不接不定式。",
      "examples": ["The book is worth reading.", "It's worth the effort."]
    }]
  },
  "suggest": {
    "collocations": [
      { "en": "suggest doing sth", "cn": "建议做某事" },
      { "en": "suggest (that) sb (should) do", "cn": "建议某人做某事" }
    ],
    "patterns": [{
      "title": "suggest + 动名词",
      "explain": "suggest 后接动名词，不接 to do。",
      "examples": ["I suggest going by train.", "He suggested that we leave early."]
    }]
  },
  "prefer": {
    "collocations": [
      { "en": "prefer A to B", "cn": "比起 B 更喜欢 A" },
      { "en": "prefer doing/to do", "cn": "更喜欢做某事" }
    ],
    "patterns": [{
      "title": "prefer ... to ...",
      "explain": "prefer A to B 中 to 是介词，后接名词或动名词。",
      "examples": ["I prefer tea to coffee.", "She prefers walking to driving."]
    }]
  },
  "need": {
    "collocations": [
      { "en": "need to do sth", "cn": "需要做某事" },
      { "en": "need doing / need to be done", "cn": "需要被……（主语是物）" },
      { "en": "needn't do", "cn": "不必做" }
    ],
    "patterns": [{
      "title": "need doing = need to be done",
      "explain": "主语是物时，need doing 表示「需要被……」，等于 need to be done。",
      "examples": ["The car needs washing.", "Your hair needs cutting."]
    }]
  },
  "can": {
    "collocations": [
      { "en": "can do sth", "cn": "能够/可以……" },
      { "en": "can't be", "cn": "不可能是（推测）" }
    ],
    "patterns": [{
      "title": "can 表能力与许可",
      "explain": "can 表能力或请求许可；could 是过去式或更委婉说法。",
      "examples": ["Can you help me?", "Could you speak more slowly?"]
    }]
  },
  "could": {
    "collocations": [
      { "en": "could do sth", "cn": "能够 / 可以（过去或委婉）" },
      { "en": "could have done", "cn": "本可以……（未实现）" }
    ]
  },
  "should": {
    "collocations": [
      { "en": "should do sth", "cn": "应该做某事" },
      { "en": "should have done", "cn": "本应该做（却没做）" }
    ]
  },
  "may": {
    "collocations": [
      { "en": "may do sth", "cn": "可能做；可以做" },
      { "en": "May I ...?", "cn": "我可以……吗？（正式许可）" }
    ]
  },
  "might": {
    "collocations": [
